generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(uuid())
  name            String           @db.VarChar(100)
  email           String           @unique @db.VarChar(255)
  passwordHash    String           @map("password_hash")
  avatarUrl       String?          @map("avatar_url")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  comments        ExpenseComment[]
  paidExpenses    Expense[]        @relation("ExpensePayer")
  createdFlats    Flat[]           @relation("FlatCreator")
  memberships     Membership[]
  notifications   Notification[]
  rentPayments    RentPayment[]
  settlementsFrom Settlement[]     @relation("SettlementFrom")
  settlementsTo   Settlement[]     @relation("SettlementTo")
  splits          Split[]
  createdRotations     Rotation[]        @relation("RotationCreator")
  assignedCycles       RotationCycle[]   @relation("CycleAssigned")
  completedCycles      RotationCycle[]   @relation("CycleCompleter")
  rotationMemberships  RotationMember[]
  rotationLogs         RotationLog[]
  createdTasks         Task[]            @relation("TaskCreator")
  assignedTasks        Task[]            @relation("TaskAssignee")
  completedTasks       Task[]            @relation("TaskCompleter")
  responsibleBills     BillReminder[]    @relation("BillResponsible")
  createdBills         BillReminder[]    @relation("BillCreator")

  @@map("users")
}

model Flat {
  id            String         @id @default(uuid())
  name          String         @db.VarChar(100)
  inviteCode    String         @unique @map("invite_code") @db.VarChar(10)
  currency      String         @default("INR") @db.VarChar(5)
  createdBy     String         @map("created_by")
  createdAt     DateTime       @default(now()) @map("created_at")
  expenses      Expense[]
  creator       User           @relation("FlatCreator", fields: [createdBy], references: [id])
  memberships   Membership[]
  notifications Notification[]
  rentCycles    RentCycle[]
  settlements   Settlement[]
  rotations     Rotation[]
  tasks         Task[]
  billReminders BillReminder[]

  @@map("flats")
}

model Membership {
  id       String   @id @default(uuid())
  flatId   String   @map("flat_id")
  userId   String   @map("user_id")
  role     Role     @default(MEMBER)
  joinedAt DateTime @default(now()) @map("joined_at")
  isActive Boolean  @default(true) @map("is_active")
  flat     Flat     @relation(fields: [flatId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([flatId, userId])
  @@index([flatId])
  @@index([userId])
  @@map("memberships")
}

model Expense {
  id         String           @id @default(uuid())
  flatId     String           @map("flat_id")
  paidBy     String           @map("paid_by")
  title      String           @db.VarChar(200)
  amount     Decimal          @db.Decimal(10, 2)
  category   Category         @default(OTHER)
  splitType  SplitType        @default(EQUAL) @map("split_type")
  note       String?
  receiptUrl String?          @map("receipt_url")
  isDisputed Boolean          @default(false) @map("is_disputed")
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")
  comments   ExpenseComment[]
  flat       Flat             @relation(fields: [flatId], references: [id], onDelete: Cascade)
  payer      User             @relation("ExpensePayer", fields: [paidBy], references: [id])
  splits     Split[]

  @@index([flatId])
  @@index([paidBy])
  @@map("expenses")
}

model Split {
  id         String  @id @default(uuid())
  expenseId  String  @map("expense_id")
  userId     String  @map("user_id")
  amountOwed Decimal @map("amount_owed") @db.Decimal(10, 2)
  isSettled  Boolean @default(false) @map("is_settled")
  expense    Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user       User    @relation(fields: [userId], references: [id])

  @@index([expenseId])
  @@index([userId])
  @@map("splits")
}

model Settlement {
  id        String        @id @default(uuid())
  flatId    String        @map("flat_id")
  fromUser  String        @map("from_user")
  toUser    String        @map("to_user")
  amount    Decimal       @db.Decimal(10, 2)
  method    PaymentMethod @default(OTHER)
  note      String?
  settledAt DateTime      @default(now()) @map("settled_at")
  flat      Flat          @relation(fields: [flatId], references: [id], onDelete: Cascade)
  payer     User          @relation("SettlementFrom", fields: [fromUser], references: [id])
  payee     User          @relation("SettlementTo", fields: [toUser], references: [id])

  @@index([flatId])
  @@index([fromUser])
  @@index([toUser])
  @@map("settlements")
}

model RentCycle {
  id              String        @id @default(uuid())
  flatId          String        @map("flat_id")
  month           String        @db.VarChar(7)
  totalAmount     Decimal       @default(0) @map("total_amount") @db.Decimal(10, 2)
  splitType       SplitType     @default(EQUAL) @map("split_type")
  dueDate         DateTime      @map("due_date") @db.Date
  isClosed        Boolean       @default(false) @map("is_closed")
  createdAt       DateTime      @default(now()) @map("created_at")
  flat            Flat          @relation(fields: [flatId], references: [id], onDelete: Cascade)
  payments        RentPayment[]

  @@index([flatId])
  @@map("rent_cycles")
}

model RentPayment {
  id          String         @id @default(uuid())
  rentCycleId String         @map("rent_cycle_id")
  userId      String         @map("user_id")
  amountOwed  Decimal        @default(0) @map("amount_owed") @db.Decimal(10, 2)
  hasPaid     Boolean        @default(false) @map("has_paid")
  isApproved  Boolean        @default(false) @map("is_approved")
  paidAt      DateTime?      @map("paid_at")
  method      PaymentMethod? @map("method")
  rentCycle   RentCycle      @relation(fields: [rentCycleId], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [userId], references: [id])

  @@unique([rentCycleId, userId])
  @@index([rentCycleId])
  @@index([userId])
  @@map("rent_payments")
}

model ExpenseComment {
  id        String   @id @default(uuid())
  expenseId String   @map("expense_id")
  userId    String   @map("user_id")
  message   String
  createdAt DateTime @default(now()) @map("created_at")
  expense   Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([expenseId])
  @@index([userId])
  @@map("expense_comments")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  flatId    String           @map("flat_id")
  type      NotificationType
  title     String           @db.VarChar(100)
  message   String           @db.VarChar(500)
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")
  flat      Flat             @relation(fields: [flatId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([flatId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

enum Role {
  ADMIN
  MEMBER
}

enum Category {
  FOOD
  UTILITIES
  RENT
  TRANSPORT
  OTHER
}

enum SplitType {
  EQUAL
  CUSTOM
}

enum PaymentMethod {
  CASH
  UPI
  BANK
  OTHER
}

enum NotificationType {
  EXPENSE_ADDED
  SETTLEMENT_CREATED
  RENT_CREATED
  RENT_PAID
  MEMBER_JOINED
  ROTATION_ASSIGNED
  ROTATION_COMPLETED
  ROTATION_OVERDUE
  TASK_ASSIGNED
  TASK_COMPLETED
  TASK_CANCELLED
  BILL_REMINDER_DUE
  BILL_REMINDER_OVERDUE
  MEMBER_LEFT
}

enum RotationFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  ON_DEMAND
}

enum CycleStatus {
  PENDING
  COMPLETED
  SKIPPED
  OVERDUE
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum BillRecurrence {
  MONTHLY
  QUARTERLY
  BIANNUAL
  ANNUAL
  CUSTOM
}

enum SchedulerStatus {
  SUCCESS
  PARTIAL
  FAILED
}

model Rotation {
  id           String           @id @default(uuid())
  flatId       String           @map("flat_id")
  name         String           @db.VarChar(100)
  description  String?          @db.Text
  frequency    RotationFrequency
  frequencyDay Int?             @map("frequency_day")
  isActive     Boolean          @default(true) @map("is_active")
  createdBy    String           @map("created_by")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  flat         Flat             @relation(fields: [flatId], references: [id], onDelete: Cascade)
  creator      User             @relation("RotationCreator", fields: [createdBy], references: [id])
  members      RotationMember[]
  cycles       RotationCycle[]
  logs         RotationLog[]

  @@index([flatId])
  @@map("rotations")
}

model RotationMember {
  id         String   @id @default(uuid())
  rotationId String   @map("rotation_id")
  userId     String   @map("user_id")
  isActive   Boolean  @default(true) @map("is_active")
  joinedAt   DateTime @default(now()) @map("joined_at")

  rotation   Rotation @relation(fields: [rotationId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([rotationId, userId])
  @@index([rotationId])
  @@map("rotation_members")
}

model RotationCycle {
  id           String      @id @default(uuid())
  rotationId   String      @map("rotation_id")
  assignedTo   String      @map("assigned_to")
  status       CycleStatus @default(PENDING)
  dueDate      DateTime    @map("due_date") @db.Date
  completedAt  DateTime?   @map("completed_at")
  completedBy  String?     @map("completed_by")
  skipReason   String?     @map("skip_reason") @db.Text
  cycleNumber  Int         @map("cycle_number")
  createdAt    DateTime    @default(now()) @map("created_at")

  rotation     Rotation    @relation(fields: [rotationId], references: [id], onDelete: Cascade)
  assignedUser User        @relation("CycleAssigned", fields: [assignedTo], references: [id])
  completer    User?       @relation("CycleCompleter", fields: [completedBy], references: [id])
  logs         RotationLog[]

  @@index([rotationId, status])
  @@map("rotation_cycles")
}

model RotationLog {
  id                String        @id @default(uuid())
  rotationId        String        @map("rotation_id")
  rotationCycleId   String        @map("rotation_cycle_id")
  userId            String        @map("user_id")
  outcome           CycleStatus   @map("outcome") // COMPLETED or SKIPPED
  loggedAt          DateTime      @default(now()) @map("logged_at")

  rotation          Rotation      @relation(fields: [rotationId], references: [id], onDelete: Cascade)
  rotationCycle     RotationCycle @relation(fields: [rotationCycleId], references: [id], onDelete: Cascade)
  user              User          @relation(fields: [userId], references: [id])

  @@index([rotationId, userId])
  @@map("rotation_logs")
}

model Task {
  id          String       @id @default(uuid())
  flatId      String       @map("flat_id")
  title       String       @db.VarChar(200)
  description String?      @db.Text
  createdBy   String       @map("created_by")
  assignedTo  String?      @map("assigned_to")
  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?    @map("due_date") @db.Date
  completedAt DateTime?    @map("completed_at")
  completedBy String?      @map("completed_by")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  flat        Flat         @relation(fields: [flatId], references: [id], onDelete: Cascade)
  creator     User         @relation("TaskCreator", fields: [createdBy], references: [id])
  assignee    User?        @relation("TaskAssignee", fields: [assignedTo], references: [id])
  completer   User?        @relation("TaskCompleter", fields: [completedBy], references: [id])

  @@index([flatId, status])
  @@index([flatId, assignedTo])
  @@map("tasks")
}

model BillReminder {
  id                 String         @id @default(uuid())
  flatId             String         @map("flat_id")
  title              String         @db.VarChar(200)
  amountEstimate     Decimal?       @map("amount_estimate") @db.Decimal(10, 2)
  category           Category       @default(OTHER)
  recurrence         BillRecurrence
  recurrenceDay      Int?           @map("recurrence_day")
  customNextDate     DateTime?      @map("custom_next_date") @db.Date
  responsibleMember  String?        @map("responsible_member")
  remindDaysBefore   Int            @default(3) @map("remind_days_before")
  isActive           Boolean        @default(true) @map("is_active")
  createdBy          String         @map("created_by")
  lastTriggeredAt    DateTime?      @map("last_triggered_at")
  nextDueDate        DateTime       @map("next_due_date") @db.Date
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  flat               Flat           @relation(fields: [flatId], references: [id], onDelete: Cascade)
  responsible        User?          @relation("BillResponsible", fields: [responsibleMember], references: [id])
  creator            User           @relation("BillCreator", fields: [createdBy], references: [id])

  @@index([flatId, nextDueDate])
  @@map("bill_reminders")
}

model SchedulerLog {
  id                 String          @id @default(uuid())
  jobName            String          @map("job_name") @db.VarChar(100)
  ranAt              DateTime        @default(now()) @map("ran_at")
  cyclesCreated      Int             @default(0) @map("cycles_created")
  notificationsSent  Int             @default(0) @map("notifications_sent")
  errors             String?         @db.Text
  status             SchedulerStatus

  @@map("scheduler_logs")
}
